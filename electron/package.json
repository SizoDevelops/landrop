{
  "name": "dropt",
  "version": "0.1.0",
  "private": true,
  "description": "Tiny LAN file-drop server, packaged as an Electron desktop app.",
  "author": "Dropt",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/SizoDevelops/dropt.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-packager . Dropt --platform=win32 --arch=x64 --out=dist-packager --overwrite --prune=true --ignore=\"(^/dist-packager$|^/dist$|\\.log$|\\.err$)\"",
    "dist": "electron-builder --win",
    "dist:portable": "electron-builder --win portable",
    "dist:nsis": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-packager": "^17.1.2",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.dropt.app",
    "productName": "Dropt",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "Dropt-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Dropt-${version}-setup.exe"
    }
  }
}
